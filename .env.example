
# Database URL for SQLite
DATABASE_URL="file:dev.db"

# Better Auth configuration
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET= # Generate a secret key: `pnpm dlx @better-auth/cli secret`

## AI
ANTHROPIC_API_KEY= # Get from https://console.anthropic.com/api-keys
OPENROUTER_API_KEY= # Get from https://openrouter.ai/api-keys
MINIMAX_API_KEY= # Optional: Get from https://platform.minimax.io — falls back to OpenRouter if not set
EXACT_API_KEY= # Get from https://exact.com/api-keys

## Default max_output_tokens applied to chat / tasks / sub-agents when the
## selected model supports a reasoning effort level. Frontmatter overrides
## still win for tasks/workflows/triggers. OpenRouter allocates ~20/50/80%
## of max_tokens to reasoning at low/medium/high — these defaults keep
## enough headroom for the final answer.
AETHER_MAX_TOKENS_LOW=40000
AETHER_MAX_TOKENS_MEDIUM=50000
AETHER_MAX_TOKENS_HIGH=100000

## Exa Search
EXA_API_KEY= # Get from https://dashboard.exa.ai
EXA_SEARCH_NUM_RESULTS=10 # Number of search results to return
EXA_SEARCH_MAX_CHARS=3000 # Max characters per search highlight snippet
EXA_FETCH_MAX_CHARS=4000 # Max characters per fetch highlight snippet

## Timezone
DEFAULT_TIMEZONE=America/Toronto # Fallback IANA timezone when user has no preference set

## Logging
LOG_LEVEL=info # debug, info, warn, error
LOG_DIR=./logs # Directory for log files (daily rotation)

## Notifications
APP_URL=http://localhost:3000 # Base URL for links in push notifications
PUSHOVER_APP_TOKEN= # Pushover application API token (https://pushover.net/apps/build)

## Obsidian
OBSIDIAN_DIR=/Users/mikevalstar/projects/test-ob
OBSIDIAN_AI_CONFIG=ai-config
OBSIDIAN_AI_MEMORY=ai-memory