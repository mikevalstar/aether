
# Database URL for SQLite
DATABASE_URL="file:dev.db"

# Better Auth configuration
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET= # Generate a secret key: `pnpm dlx @better-auth/cli secret`

## AI
ANTHROPIC_API_KEY= # Get from https://console.anthropic.com/api-keys

## Logging
LOG_LEVEL=info # debug, info, warn, error
LOG_DIR=./logs # Directory for log files (daily rotation)

## Notifications
APP_URL=http://localhost:3000 # Base URL for links in push notifications
PUSHOVER_APP_TOKEN= # Pushover application API token (https://pushover.net/apps/build)

## Obsidian
OBSIDIAN_DIR=/Users/mikevalstar/projects/test-ob
OBSIDIAN_AI_CONFIG=ai-config
OBSIDIAN_AI_MEMORY=ai-memory