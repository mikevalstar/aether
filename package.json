{
  "name": "aether",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "dev:tunnel": "concurrently \"vite dev --port 3000 --host\" \"cloudflared tunnel run aether-test\"",
    "tunnel": "cloudflared tunnel run aether-test",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "post-cta-init": "pnpm dlx create-db@latest --user-agent tanstack/tsrouter",
    "db:generate": "dotenv -e .env -- prisma generate",
    "db:push": "dotenv -e .env -- prisma db push",
    "db:migrate": "dotenv -e .env -- prisma migrate dev",
    "db:studio": "dotenv -e .env -- prisma studio",
    "db:seed": "dotenv -e .env -- prisma db seed",
    "create:first-admin": "dotenv -e .env -- tsx scripts/create-first-admin.ts",
    "ai-config:seed": "dotenv -e .env -- tsx scripts/ai-config-seed.ts",
    "ai-config:pull": "dotenv -e .env -- tsx scripts/ai-config-pull.ts",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "check:fix": "biome check --write",
    "type-check": "tsc --noEmit",
    "type-check:fix": "tsc --noEmit --fix",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/react": "^3.0.142",
    "@assistant-ui/react": "^0.12.21",
    "@assistant-ui/react-ai-sdk": "^1.3.16",
    "@assistant-ui/react-markdown": "^0.12.7",
    "@dnd-kit/abstract": "^0.3.2",
    "@dnd-kit/helpers": "^0.3.2",
    "@dnd-kit/react": "^0.3.2",
    "@gorgonjs/gorgon": "^1.6.1",
    "@libsql/client": "^0.17.2",
    "@mozilla/readability": "^0.6.0",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@storybook/test": "^8.6.15",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-devtools": "0.10.0",
    "@tanstack/react-form": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.167.8",
    "@types/jmespath": "^0.15.2",
    "@uiw/react-md-editor": "^4.0.11",
    "ai": "^6.0.140",
    "better-auth": "^1.5.6",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "croner": "^10.0.1",
    "cronstrue": "^3.14.0",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.20",
    "diff": "^8.0.4",
    "dotenv": "^17.3.1",
    "error-stack-parser-es": "^1.0.5",
    "exa-js": "^2.10.2",
    "fuse.js": "^7.1.0",
    "globby": "^16.1.1",
