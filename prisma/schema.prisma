generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Todo {
  id        Int      @id @default(autoincrement())
  title     String
  createdAt DateTime @default(now())
}

// Better Auth models
model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  role          String    @default("user")
  preferences   String    @default("{}")
  mustChangePassword Boolean @default(false)
  invitedById   String?
  createdAt     DateTime
  updatedAt     DateTime
  invitedBy     User?     @relation("UserInvites", fields: [invitedById], references: [id])
  invitedUsers  User[]    @relation("UserInvites")
  sessions      Session[]
  accounts      Account[]
  chatThreads   ChatThread[]
  chatUsageEvents ChatUsageEvent[]
  activityLogs    ActivityLog[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

model ChatThread {
  id           String   @id
  title        String   @default("New chat")
  model        String   @default("claude-haiku-4-5")
  effort       String   @default("low")
  messagesJson String   @default("[]")
  usageHistoryJson String @default("[]")
  totalInputTokens Int    @default(0)
  totalOutputTokens Int   @default(0)
  totalEstimatedCostUsd Float @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model ChatUsageEvent {
  id                String   @id
  model             String
  taskType          String   @default("chat")
  inputTokens       Int
  outputTokens      Int
  totalTokens       Int
  estimatedCostUsd  Float
  createdAt         DateTime @default(now())
  threadId          String?
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, model, createdAt])
}

model ActivityLog {
  id               String             @id @default(cuid())
  type             String
  summary          String
  metadata         String?
  createdAt        DateTime           @default(now())
  userId           String
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileChangeDetail FileChangeDetail?

  @@index([userId, createdAt])
  @@index([userId, type, createdAt])
}

model FileChangeDetail {
  id              String      @id @default(cuid())
  activityLogId   String      @unique
  activityLog     ActivityLog @relation(fields: [activityLogId], references: [id], onDelete: Cascade)
  filePath        String
  originalContent String?
  newContent      String
  changeSource    String
  toolName        String?
}
